{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "launcher",
  "version": "0.1.0",
  "identifier": "decent-client.launcher.gg",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Decent Client - Launcher",
        "label": "launcher",
        "width": 1086,
        "height": 548,
        "minWidth": 792,
        "minHeight": 540,
        "center": true,
        "resizable": true,
        "transparent": true
      },
      {
        "title": "Decent Client",
        "label": "splash-screen",
        "url": "splash-screen",
        "width": 400,
        "height": 200,
        "center": true,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "visible": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
